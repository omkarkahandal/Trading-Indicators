// @version=5
indicator("Live Candle-Based OB Detector [v4]", "Live OB Detector v4", overlay=true, max_boxes_count=500)

// --- User Inputs for Customization ---
// These inputs allow you to fine-tune the indicator's behavior.

// General Settings
g_general = "General Settings"
bool showBullishOB = input.bool(true, title="Show Bullish Order Blocks", group=g_general)
bool showBearishOB = input.bool(true, title="Show Bearish Order Blocks", group=g_general)
bool useBody = input.bool(true, title="Use Candle Body for OB Zone", tooltip="If checked, the order block zone is the candle's body. If unchecked, it's the full wick-to-wick range.", group=g_general)

// Confirmation Filters (Disabled by default for more signals)
g_filters = "Confirmation Filters (Optional)"
bool useVolumeFilter = input.bool(false, title="Enable Volume Filter", tooltip="If enabled, an OB is only valid if the confirmation candle has above-average volume.", group=g_filters)
int volumeLookback = input.int(20, title="Volume Lookback", minval=1, group=g_filters)
bool useImbalanceFilter = input.bool(false, title="Enable Imbalance (FVG) Filter", tooltip="If enabled, an OB is only valid if the confirmation candle creates a Fair Value Gap.", group=g_filters)

// Visual Settings
g_visual = "Visual Settings"
color bullishOBColor = input.color(color.new(color.blue, 80), title="Bullish OB Color", group=g_visual)
color bearishOBColor = input.color(color.new(color.purple, 80), title="Bearish OB Color", group=g_visual)
color textColor = input.color(color.white, title="Text Color", group=g_visual)


// --- Variable Declarations ---
// Arrays to store and manage the drawn order block boxes.
var box[] bullishOBs = array.new_box()
var box[] bearishOBs = array.new_box()

// --- Core Logic: Live Order Block Detection ---
// This logic identifies order blocks in real-time by looking for an immediate
// break of structure (BOS) on a candle-by-candle basis.

// Filter Calculations
// -------------------
// Volume analysis (only used if the filter is enabled).
float avgVolume = ta.sma(volume, volumeLookback)
bool isHighVolume = volume > avgVolume or not useVolumeFilter

// Bullish Order Block Logic
// -------------------------
// A live bullish OB is a down-candle whose high is immediately taken by the very next candle.
// Condition 1: The previous candle [1] was a down-candle (the potential Order Block).
bool isPotentialBullishOB = close[1] < open[1]
// Condition 2: The current candle [0] is the confirmation candle. It must break the high of the previous candle. This is the live "Break of Structure".
bool hasBullishBOS = high > high[1]
// Condition 3 (Optional Filter): An imbalance (Fair Value Gap) is created.
bool hasBullishImbalance = low > high[2] or not useImbalanceFilter

// If all conditions are met, draw the bullish order block.
if isPotentialBullishOB and hasBullishBOS and isHighVolume and hasBullishImbalance and showBullishOB
    // The order block is the body or full range of the previous candle [1].
    float ob_top = useBody ? open[1] : high[1]
    float ob_bottom = useBody ? close[1] : low[1]
    box ob = box.new(
         left=bar_index[1],
         top=ob_top,
         right=bar_index,
         bottom=ob_bottom,
         bgcolor=bullishOBColor,
         border_color=color.new(color.blue, 40),
         text="Bullish OB",
         text_color=textColor,
         text_size=size.tiny,
         extend=extend.right
         )
    array.push(bullishOBs, ob)

// Bearish Order Block Logic
// -------------------------
// A live bearish OB is an up-candle whose low is immediately taken by the very next candle.
// Condition 1: The previous candle [1] was an up-candle (the potential Order Block).
bool isPotentialBearishOB = close[1] > open[1]
// Condition 2: The current candle [0] is the confirmation candle. It must break the low of the previous candle. This is the live "Break of Structure".
bool hasBearishBOS = low < low[1]
// Condition 3 (Optional Filter): An imbalance (Fair Value Gap) is created.
bool hasBearishImbalance = high < low[2] or not useImbalanceFilter

// If all conditions are met, draw the bearish order block.
if isPotentialBearishOB and hasBearishBOS and isHighVolume and hasBearishImbalance and showBearishOB
    // The order block is the body or full range of the previous candle [1].
    float ob_top = useBody ? close[1] : high[1]
    float ob_bottom = useBody ? open[1] : low[1]
    box ob = box.new(
         left=bar_index[1],
         top=ob_top,
         right=bar_index,
         bottom=ob_bottom,
         bgcolor=bearishOBColor,
         border_color=color.new(color.purple, 40),
         text="Bearish OB",
         text_color=textColor,
         text_size=size.tiny,
         extend=extend.right
         )
    array.push(bearishOBs, ob)


// --- Managing Order Blocks (Mitigation) ---
// This section removes the order block boxes once price trades back into them.
// This keeps the chart clean and focuses only on fresh, un-tested zones.

// Check for mitigation of bullish order blocks.
if array.size(bullishOBs) > 0
    for i = array.size(bullishOBs) - 1 to 0
        box ob = array.get(bullishOBs, i)
        float ob_bottom = box.get_bottom(ob) // Get the bottom price of the bullish OB box.
        
        // FIX: A bullish OB is mitigated if price CLOSES BELOW its low.
        // This prevents the box from being deleted by a simple wick into the zone.
        if close < ob_bottom
            box.delete(ob) // Delete the box from the chart.
            array.remove(bullishOBs, i) // Remove the box from our array.

// Check for mitigation of bearish order blocks.
if array.size(bearishOBs) > 0
    for i = array.size(bearishOBs) - 1 to 0
        box ob = array.get(bearishOBs, i)
        float ob_top = box.get_top(ob) // Get the top price of the bearish OB box.

        // FIX: A bearish OB is mitigated if price CLOSES ABOVE its high.
        // This prevents the box from being deleted by a simple wick into the zone.
        if close > ob_top
            box.delete(ob) // Delete the box from the chart.
            array.remove(bearishOBs, i) // Remove the box from our array.