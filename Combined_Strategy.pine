//@version=6
strategy("Combined OB + Astro Strategy", shorttitle="OB+Astro", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=2, commission_value=0.04, max_boxes_count=500)

// ==========================================
// --- OB DETECTOR INPUTS (From Script 1) ---
// ==========================================
g_general = "OB: General Settings"
showBullishOB = input.bool(true, title="Show Bullish Order Blocks", group=g_general)
showBearishOB = input.bool(true, title="Show Bearish Order Blocks", group=g_general)
useBody = input.bool(true, title="Use Candle Body for OB Zone", tooltip="If checked, the order block zone is the candle's body. If unchecked, it's the full wick-to-wick range.", group=g_general)

g_filters = "OB: Confirmation Filters (Optional)"
useVolumeFilter = input.bool(false, title="Enable Volume Filter", tooltip="If enabled, an OB is only valid if the confirmation candle has above-average volume.", group=g_filters)
volumeLookback = input.int(20, title="Volume Lookback", minval=1, group=g_filters)
useImbalanceFilter = input.bool(false, title="Enable Imbalance (FVG) Filter", tooltip="If enabled, an OB is only valid if the confirmation candle creates a Fair Value Gap.", group=g_filters)

g_visual = "OB: Visual Settings"
bullishOBColor = input.color(color.new(color.blue, 80), title="Bullish OB Color", group=g_visual)
bearishOBColor = input.color(color.new(color.purple, 80), title="Bearish OB Color", group=g_visual)
textColor = input.color(color.white, title="Text Color", group=g_visual)

// ==========================================
// --- ASTRO STRATEGY INPUTS (From Script 2) ---
// ==========================================
g_astro_set = "Astro: Settings"
lookback = input.int(12, "Lookback Period", minval=5, group=g_astro_set)
rrRatio = input.float(2.5, "Risk:Reward", minval=1.5, group="Astro: Risk Management")
showOnlyStrong = input.bool(true, "Show Only Strong Signals", group="Astro: Filter")

// --- INTERACTION FILTER ---
g_interaction = "Strategy Interaction"
requireOB = input.bool(false, "Require Price in Order Block to Signal", tooltip="If true, the Astro strategy will only fire Buy/Sell signals if the price is currently inside an active Order Block.", group=g_interaction)

// ==========================================
// --- OB DETECTOR LOGIC (From Script 1) ---
// ==========================================
var array<box> bullishOBs = array.new<box>()
var array<box> bearishOBs = array.new<box>()

// Filter Calculations
float avgVolume = ta.sma(volume, volumeLookback)
bool isHighVolume = volume > avgVolume or not useVolumeFilter

// Bullish Order Block Logic
bool isPotentialBullishOB = close[1] < open[1]
bool hasBullishBOS = high > high[1]
bool hasBullishImbalance = low > high[2] or not useImbalanceFilter

if isPotentialBullishOB and hasBullishBOS and isHighVolume and hasBullishImbalance and showBullishOB
    float ob_top = useBody ? open[1] : high[1]
    float ob_bottom = useBody ? close[1] : low[1]
    box ob = box.new(left=bar_index[1], top=ob_top, right=bar_index, bottom=ob_bottom, bgcolor=bullishOBColor, border_color=color.new(color.blue, 40), text="Bullish OB", text_color=textColor, text_size=size.tiny, extend=extend.right)
    array.push(bullishOBs, ob)

// Bearish Order Block Logic
bool isPotentialBearishOB = close[1] > open[1]
bool hasBearishBOS = low < low[1]
bool hasBearishImbalance = high < low[2] or not useImbalanceFilter

if isPotentialBearishOB and hasBearishBOS and isHighVolume and hasBearishImbalance and showBearishOB
    float ob_top = useBody ? close[1] : high[1]
    float ob_bottom = useBody ? open[1] : low[1]
    box ob = box.new(left=bar_index[1], top=ob_top, right=bar_index, bottom=ob_bottom, bgcolor=bearishOBColor, border_color=color.new(color.purple, 40), text="Bearish OB", text_color=textColor, text_size=size.tiny, extend=extend.right)
    array.push(bearishOBs, ob)

// Manage Mitigation
if array.size(bullishOBs) > 0
    for i = array.size(bullishOBs) - 1 to 0
        box ob = array.get(bullishOBs, i)
        float ob_bottom = box.get_bottom(ob)
        if close < ob_bottom
            box.delete(ob)
            array.remove(bullishOBs, i)

if array.size(bearishOBs) > 0
    for i = array.size(bearishOBs) - 1 to 0
        box ob = array.get(bearishOBs, i)
        float ob_top = box.get_top(ob)
        if close > ob_top
            box.delete(ob)
            array.remove(bearishOBs, i)

// ==========================================
// --- INTERACTION LOGIC (Communication) ---
// ==========================================
bool priceInBullOB = false
if array.size(bullishOBs) > 0
    for i = 0 to array.size(bullishOBs) - 1
        box ob = array.get(bullishOBs, i)
        if close >= box.get_bottom(ob) and close <= box.get_top(ob)
            priceInBullOB := true
            break

bool priceInBearOB = false
if array.size(bearishOBs) > 0
    for i = 0 to array.size(bearishOBs) - 1
        box ob = array.get(bearishOBs, i)
        if close >= box.get_bottom(ob) and close <= box.get_top(ob)
            priceInBearOB := true
            break

// ==========================================
// --- ASTRO STRATEGY LOGIC (From Script 2) ---
// ==========================================
float swingLow = ta.pivotlow(low, lookback, lookback)
float swingHigh = ta.pivothigh(high, lookback, lookback)
bool hasSwingLow = not na(swingLow)
bool hasSwingHigh = not na(swingHigh)

float candleRange = high - low
float avgRange = ta.sma(candleRange, 20)
bool crtBull = candleRange > avgRange * 1.65 and close > open
bool crtBear = candleRange > avgRange * 1.65 and close < open

float cycle1 = math.sin(2 * math.pi * (time / 86400000 / 27.3))
float cycle2 = math.sin(2 * math.pi * (time / 86400000 / 29.53))
float cycle3 = math.sin(2 * math.pi * (time / 86400000 / 88))
float cycle4 = math.sin(2 * math.pi * (time / 86400000 / 225))

float astroScore = (cycle1 + cycle2 + cycle3 + cycle4) * 25
float moonPhase = (time % (86400000 * 29.53)) / (86400000 * 29.53) * 100

bool strongBull = astroScore > 48 and moonPhase > 52
bool strongBear = astroScore < -48 and moonPhase < 48

bool rawBuySignal = crtBull and strongBull and (not showOnlyStrong or hasSwingLow)
bool rawSellSignal = crtBear and strongBear and (not showOnlyStrong or hasSwingHigh)

// ---> Apply the Real-Time Communication Filter
bool finalBuy = rawBuySignal and (not requireOB or priceInBullOB)
bool finalSell = rawSellSignal and (not requireOB or priceInBearOB)

bgcolor(finalBuy ? color.new(color.green, 85) : (finalSell ? color.new(color.red, 85) : na))

var float longSL = na
var float shortSL = na

if finalBuy and strategy.position_size == 0
    longSL := hasSwingLow ? swingLow : low
    strategy.entry("BUY", strategy.long)

if finalSell and strategy.position_size == 0
    shortSL := hasSwingHigh ? swingHigh : high
    strategy.entry("SELL", strategy.short)

if strategy.position_size > 0
    float longTP = strategy.position_avg_price + (strategy.position_avg_price - longSL) * rrRatio
    strategy.exit("Exit Buy", "BUY", stop=longSL, limit=longTP)

if strategy.position_size < 0
    float shortTP = strategy.position_avg_price - (shortSL - strategy.position_avg_price) * rrRatio
    strategy.exit("Exit Sell", "SELL", stop=shortSL, limit=shortTP)

plotshape(finalBuy, title="BUY SIGNAL", location=location.belowbar, color=color.lime, style=shape.labelup, size=size.large, text="BUY", textcolor=color.black)
plotshape(finalSell, title="SELL SIGNAL", location=location.abovebar, color=color.red, style=shape.labeldown, size=size.large, text="SELL", textcolor=color.white)

plot(hasSwingLow ? swingLow : na, "Swing Low", color=color.green, style=plot.style_linebr, linewidth=2)
plot(hasSwingHigh ? swingHigh : na, "Swing High", color=color.red, style=plot.style_linebr, linewidth=2)
